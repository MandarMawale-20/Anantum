# =============================================================================
# Anantum v2 — Environment Configuration
# =============================================================================
# Copy this file to .env and replace with your local values.
# All settings have sensible defaults; you only need to set LLM_MODEL_PATH.
#
# Required settings (must be configured):
#   LLM_MODEL_PATH  — Path to your GGUF model file
#
# Optional settings (defaults shown):
#   LLM_N_GPU_LAYERS — GPU offload layers (0 = CPU only)
#   TTS_VOICE        — Kokoro voice code
#   WAKE_WORD_ENABLED — Enable/disable wake word detection
# =============================================================================

# --- Core Model Settings ---
# Path to your GGUF model file (e.g., models/gemma-2-2b-it-Q4_K_M.gguf)
LLM_MODEL_PATH=models/your-model.gguf

# Number of layers to offload to GPU (0 = CPU only, 35 = most of a 1B model)
LLM_N_GPU_LAYERS=35

# Context window size in tokens
LLM_N_CTX=2048

# Number of CPU threads for inference
LLM_N_THREADS=4

# --- Speech-to-Text (STT) ---
# HuggingFace model ID for faster-whisper
STT_MODEL=ctranslate2-4you/distil-whisper-small.en-ct2-float32

# Device for STT inference: cpu, cuda, auto
STT_DEVICE=cpu

# Compute type: int8, int8_float16, float16
STT_COMPUTE=int8

# --- Text-to-Speech (TTS) ---
# Kokoro voice code (e.g., af_bella, af_sky, am_adam)
TTS_VOICE=af_bella

# TTS device: auto, cuda, cpu
TTS_DEVICE=auto

# --- Wake Word ---
# Enable/disable wake word detection
WAKE_WORD_ENABLED=true

# Detection threshold (0.0–1.0, lower = more sensitive)
WAKE_WORD_THRESHOLD=0.5

# Semicolon-separated paths to OpenWakeWord ONNX models
WAKE_WORD_MODELS=models/wake/anantum.onnx;models/wake/anantam.onnx

# --- Runtime Tuning ---
# Audio sample rate for recording
SAMPLE_RATE=16000

# Silence threshold for voice activity detection
SILENCE_THRESHOLD=400

# Seconds of silence before stopping recording
SILENCE_DURATION=1.8

# Minimum speech chunks to process
MIN_SPEECH_CHUNKS=8

# Maximum recording duration in seconds
MAX_RECORD_SECONDS=30

# Minimum response length in characters
MIN_RESPONSE_LENGTH=3